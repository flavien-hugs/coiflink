# Dependencies
node_modules/
adw_sdlc/node_modules/

# Build output
adw_sdlc/dist/

# ADW run workspaces / state (per-run, not source)
agents/

# Local run config / secrets for scripts/run-issue.sh (never commit credentials)
scripts/adw.env

# Test / tooling caches
.pytest_cache/
__pycache__/
*.tsbuildinfo
.vitest/

# --- Paquets applicatifs (#2) ---
# Ne JAMAIS ignorer les *.env.example (placeholders versionnés) ; seuls les .env réels sont ignorés.

# backend/ (FastAPI / Python)
backend/.venv/
*.egg-info/
backend/.env

# web-dashboard/ (Next.js / Node) — node_modules déjà couvert globalement
web-dashboard/.next/
web-dashboard/out/
web-dashboard/.env*.local

# app-mobile/ (Flutter) — voir aussi app-mobile/.gitignore (motifs détaillés générés par Flutter)
app-mobile/build/
app-mobile/.dart_tool/
app-mobile/.env

# OS / editor
.DS_Store
*.swp

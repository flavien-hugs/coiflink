# Local config for scripts/run-issue.sh — copy to scripts/adw.env and fill in.
# scripts/adw.env is gitignored: never commit real credentials.
#
# Every line here is `export`ed into the run-issue.sh environment, which then
# forwards the allowlisted subset to the orchestrator (the agent never sees
# MX_AGENT_* / MATRIX_* — that is the secret boundary in adw_sdlc/src/env.ts).

# --- runner selection -------------------------------------------------------
# claude (default) | codex | opencode | pi
MX_AGENT_RUNNER=claude

# --- runner credential (set the one matching MX_AGENT_RUNNER) ----------------
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# CODEX_API_KEY=

# --- project wiring ---------------------------------------------------------
# owner/repo for issue lookups (omit to use the current repo)
# REPO=owner/repo

# The project's test gate (issue #6). Runs during `resolve` and as a pre-merge
# gate; empty => skipped (treated as green). See docs/strategie-de-tests.md.
#
# The orchestrator splits this on quotes only and runs it WITHOUT a shell (no
# `&&`, `;`, `|`, `>`, glob or `$VAR`), so a multi-package run lives in a
# committed wrapper — scripts/test-gate.sh — invoked via a trivial argv command.
# run-issue.sh runs the CLI from adw_sdlc/, so reference the wrapper relatively
# from there (the wrapper re-anchors itself to the repo root):
MX_AGENT_TEST_CMD="bash ../scripts/test-gate.sh"
#
# Optionally scope the gate to the packages whose toolchain is installed
# (default: all three — backend web mobile). Fail-closed: a selected package
# with no toolchain fails the gate.
# TEST_GATE_PACKAGES=backend

# Extra pre-merge gates, ONE PER LINE (use $'...\n...' for multiple).
# Example: MX_AGENT_FINALIZE_GATES=$'npm run lint\nnpm run build'
# MX_AGENT_FINALIZE_GATES=

# Move the issue's card on this GitHub Project board number (optional).
# PROJECT_NUMBER=1

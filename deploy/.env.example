# Gabarit NON secret pour `deploy/docker-compose.yml` (issue #5).
# Copier en `deploy/.env` (gitignoré) puis renseigner localement.
#
# RÈGLES :
# - Ne JAMAIS committer de valeur réelle ni de secret de staging/prod ici.
#   Ce fichier ne contient que des PLACEHOLDERS pour un environnement LOCAL
#   jetable. Les secrets réels (staging/prod) vivent hors dépôt, dans le magasin
#   de secrets de la plateforme — voir docs/environnements-et-secrets.md.
# - Les secrets sont volontairement laissés VIDES : un secret absent doit faire
#   échouer le démarrage proprement (fail-fast), c'est le comportement attendu.

# --- PostgreSQL local (service `postgres`) --------------------------------- #
POSTGRES_USER=coiflink
# Mot de passe d'une base LOCALE jetable, à définir soi-même (jamais un secret
# de prod). Laisser vide fait échouer `docker compose up` (fail-fast attendu).
POSTGRES_PASSWORD=
POSTGRES_DB=coiflink
POSTGRES_PORT=5432

# --- Redis local (service `redis`) ----------------------------------------- #
REDIS_PORT=6379

# --- backend (FastAPI) ----------------------------------------------------- #
# DSN de connexion consommé par le backend + Alembic. DOIT refléter les
# POSTGRES_* ci-dessus (même utilisateur / mot de passe / base). L'hôte est le
# nom du service compose (`postgres`), pas `localhost`. Remplacer <MOT_DE_PASSE>.
DATABASE_URL=postgresql://coiflink:<MOT_DE_PASSE>@postgres:5432/coiflink
REDIS_URL=redis://redis:6379/0
# Secret de signature JWT — requis à partir de #8 (auth) ; laisser vide sinon.
JWT_SECRET=
APP_NAME=CoifLink API
# development | staging | production (convention APP_ENV, cf. main.py).
APP_ENV=development
BACKEND_PORT=8000

# --- web-dashboard (Next.js) ----------------------------------------------- #
# NEXT_PUBLIC_* est EXPOSÉ AU NAVIGATEUR → ne jamais y mettre de secret.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
WEB_PORT=3000

# --- Images (parité staging/prod) ------------------------------------------ #
# Tag des images backend/web. En local : `local` (build depuis le Dockerfile).
IMAGE_TAG=local

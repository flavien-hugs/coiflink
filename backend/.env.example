# Configuration du backend CoifLink — gabarit NON secret.
# Copier en `backend/.env` (ignoré par git) puis renseigner localement.
# Ne JAMAIS committer de valeur réelle ni de secret. Politique de secrets & matrice
# de configuration : ../docs/environnements-et-secrets.md (décision : ADR-0011).
# Les secrets réels (staging/prod) vivent hors dépôt (magasin de la plateforme),
# injectés par variables d'environnement à l'exécution.

# --- Connexions de données --------------------------------------------------
# DATABASE_URL — SECRET (staging/prod). Pilote l'application ET les migrations
# Alembic (issue #3) : `migrations/env.py` lit cette variable et force le driver
# psycopg 3 (`postgresql://` normalisé en `postgresql+psycopg://`). PostgreSQL 16.
DATABASE_URL=postgresql://user:password@localhost:5432/coiflink
# REDIS_URL — SECRET (staging/prod) ; non sensible en local (Redis sans mot de passe).
REDIS_URL=redis://localhost:6379/0

# JWT_SECRET — SECRET, REQUIS pour la connexion (issue #10) : signe les JWT
# d'accès/refresh (HS256, ADR-0013). Laissé VIDE dans ce gabarit ; la valeur réelle
# (forte entropie) vit hors dépôt (magasin de la plateforme). Sans lui, `/auth/login`
# et `/auth/refresh` répondent 503 — `GET /health` et l'inscription restent OK.
JWT_SECRET=

# --- Connexion / JWT (issue #10, NON secret) --------------------------------
# Réglages non sensibles de l'émission de jetons et de l'anti-bruteforce ; défauts
# sûrs appliqués si absents (cf. coiflink_api/config.py).
#   JWT_ALGORITHM (défaut HS256) — algorithme de signature symétrique.
#   JWT_ACCESS_TTL_SECONDS (défaut 900 = 15 min) — durée du jeton d'accès (court).
#   JWT_REFRESH_TTL_SECONDS (défaut 2592000 = 30 j) — durée du refresh (long, rotaté).
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# Anti-bruteforce sur les échecs de connexion (§11.1) : seuil sur fenêtre glissante
# puis verrou temporisé (429 + Retry-After) ; un succès réinitialise le compteur.
#   LOGIN_MAX_ATTEMPTS (défaut 5) · LOGIN_WINDOW_SECONDS (défaut 300) ·
#   LOGIN_LOCKOUT_SECONDS (défaut 900).
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=900

# --- Authentification / OTP (issue #8, NON secret) --------------------------
# OTP_ENABLED : active la génération/l'envoi d'un OTP à l'inscription. Désactivé
# par défaut (false) — l'envoi SMS réel dépend de l'infra notifications (M5,
# ADR-0006) ; en #8 l'envoi est un stub. La capacité OTP reste testable même
# désactivée. Paramètres optionnels de l'OTP (défauts sûrs si absents) :
#   OTP_CODE_LENGTH (défaut 6) · OTP_TTL_SECONDS (défaut 300) · OTP_MAX_ATTEMPTS (défaut 3).
OTP_ENABLED=false

# --- Métadonnées d'exécution (NON secret) -----------------------------------
APP_NAME=CoifLink API
# APP_ENV : development | staging | production (lu par coiflink_api/main.py).
APP_ENV=development

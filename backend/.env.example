# Configuration du backend CoifLink — gabarit NON secret.
# Copier en `backend/.env` (ignoré par git) puis renseigner localement.
# Ne JAMAIS committer de valeur réelle ni de secret : l'injection des secrets
# hors dépôt est l'objet de l'issue #5.

# Connexions de données (placeholders non secrets, forme attendue).
# DATABASE_URL pilote l'application ET les migrations Alembic (issue #3) :
# `migrations/env.py` lit cette variable et force le driver psycopg 3
# (`postgresql://` est normalisé en `postgresql+psycopg://`). Aucun identifiant
# réel n'est committé — injection des secrets hors dépôt en #5. PostgreSQL 16.
DATABASE_URL=postgresql://user:password@localhost:5432/coiflink
REDIS_URL=redis://localhost:6379/0

# Secret de signature JWT — laissé VIDE volontairement : injecté hors dépôt (#5).
JWT_SECRET=

# Métadonnées d'exécution (non sensibles).
APP_NAME=CoifLink API
APP_ENV=development

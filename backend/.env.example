# Configuration du backend CoifLink — gabarit NON secret.
# Copier en `backend/.env` (ignoré par git) puis renseigner localement.
# Ne JAMAIS committer de valeur réelle ni de secret. Politique de secrets & matrice
# de configuration : ../docs/environnements-et-secrets.md (décision : ADR-0011).
# Les secrets réels (staging/prod) vivent hors dépôt (magasin de la plateforme),
# injectés par variables d'environnement à l'exécution.

# --- Connexions de données --------------------------------------------------
# DATABASE_URL — SECRET (staging/prod). Pilote l'application ET les migrations
# Alembic (issue #3) : `migrations/env.py` lit cette variable et force le driver
# psycopg 3 (`postgresql://` normalisé en `postgresql+psycopg://`). PostgreSQL 16.
DATABASE_URL=postgresql://user:password@localhost:5432/coiflink
# REDIS_URL — SECRET (staging/prod) ; non sensible en local (Redis sans mot de passe).
REDIS_URL=redis://localhost:6379/0

# JWT_SECRET — SECRET, requis dès #8 (auth) ; laissé VIDE tant qu'inutilisé.
JWT_SECRET=

# --- Métadonnées d'exécution (NON secret) -----------------------------------
APP_NAME=CoifLink API
# APP_ENV : development | staging | production (lu par coiflink_api/main.py).
APP_ENV=development
